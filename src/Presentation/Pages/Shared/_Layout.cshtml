<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Proceso SRI</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/InvoiceApp.Presentation.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <header class="app-header">
            <div class="app-container app-header__inner">
                <a class="brand-link" asp-area="" asp-page="/Index" aria-label="Ir al inicio">
                    <span class="brand-mark" aria-hidden="true">SRI</span>
                    <span>
                        <span class="brand-title">Proceso SRI</span>
                        <span class="brand-subtitle">Devolución de IVA</span>
                    </span>
                </a>
                <nav aria-label="Navegación principal">
                    <a class="nav-action" asp-area="" asp-page="/Historial">Historial</a>
                </nav>
            </div>
        </header>

        <main role="main">
            @RenderBody()
        </main>

        <footer class="app-container app-footer">
            ¿Necesitas ayuda? Llama a tu familiar o contador de confianza.
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
