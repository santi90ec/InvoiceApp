@page
@model InvoiceApp.Presentation.Pages.IndexModel
@{
    ViewData["Title"] = "Inicio";
}

<section class="app-container page-section">
    <div class="page-heading">
        <h1>Bienvenido</h1>
        <p>Te ayudamos a hacer tu Devolución de IVA, paso a paso.</p>
    </div>

    <div class="home-grid">
        <section class="app-card app-card--hero">
            <div class="card-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                    <path d="M14 2v6h6"></path>
                    <path d="M9 15h6"></path>
                    <path d="M9 11h3"></path>
                </svg>
            </div>
            <div>
                <h2>¿Qué hace esta aplicación?</h2>
                <p>
                    Esta aplicación te guía para revisar tus facturas electrónicas y preparar tu
                    Devolución de IVA. No necesitas conocimientos técnicos: te llevamos paso a paso.
                </p>
            </div>
            <div class="button-row">
                <a class="big-button big-button--primary" asp-page="/Paso1">
                    Empezar Proceso
                    <span aria-hidden="true">→</span>
                </a>
            </div>
        </section>

        <section class="app-card app-card--muted" aria-labelledby="last-run-title">
            <div class="card-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false">
                    <path d="M9 11l3 3L22 4"></path>
                    <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
                </svg>
            </div>
            <div>
                <h2 id="last-run-title">Última ejecución</h2>
                <p>Aún no hay un proceso guardado en el historial local.</p>
            </div>
            <div class="button-row">
                <a class="big-button big-button--secondary" asp-page="/Historial">Ver historial</a>
            </div>
        </section>

        <div class="app-alert" role="status">
            <strong>Tus datos están seguros</strong>
            <span>Esta aplicación procesa tus XML localmente. No guardamos contraseñas.</span>
        </div>
    </div>
</section>
