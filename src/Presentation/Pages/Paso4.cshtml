@page "/paso-4"
@model InvoiceApp.Presentation.Pages.Paso4Model
@{
    ViewData["Title"] = "Paso 4: Iniciar proceso";
}

<nav aria-label="Paso 4 de 5" class="stepper-shell">
    <ol class="app-container stepper">
        <li class="stepper__item stepper__item--done">
            <span class="stepper__circle" aria-hidden="true">✓</span>
            <span class="stepper__text"><span>Paso 1</span><small>Carpeta</small></span>
            <span class="stepper__line" aria-hidden="true"></span>
        </li>
        <li class="stepper__item stepper__item--done">
            <span class="stepper__circle" aria-hidden="true">✓</span>
            <span class="stepper__text"><span>Paso 2</span><small>Revisar</small></span>
            <span class="stepper__line" aria-hidden="true"></span>
        </li>
        <li class="stepper__item stepper__item--done">
            <span class="stepper__circle" aria-hidden="true">✓</span>
            <span class="stepper__text"><span>Paso 3</span><small>Clasificar</small></span>
            <span class="stepper__line" aria-hidden="true"></span>
        </li>
        <li class="stepper__item stepper__item--active">
            <span class="stepper__circle" aria-current="step">4</span>
            <span class="stepper__text"><span>Paso 4</span><small>Iniciar</small></span>
            <span class="stepper__line" aria-hidden="true"></span>
        </li>
        <li class="stepper__item">
            <span class="stepper__circle">5</span>
            <span class="stepper__text"><span>Paso 5</span><small>Resultados</small></span>
        </li>
    </ol>
</nav>

<section class="app-container page-section">
    <div class="page-heading">
        <h1>Clasificación lista</h1>
        <p>Tus facturas ya están organizadas. El inicio automático del proceso SRI no forma parte de este POC.</p>
    </div>

    <div class="app-alert" role="status">
        <strong>Datos preparados</strong>
        <span>@Model.Invoices.Count factura(s) clasificadas durante esta sesión.</span>
    </div>

    <div class="button-row page-actions">
        <a class="big-button big-button--secondary" asp-page="/Paso3">Volver a clasificar</a>
        <a class="big-button big-button--primary" asp-page="/Index">Ir al inicio</a>
    </div>
</section>
